{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Plinth",
  "version": "0.1.0-beta.2",
  "identifier": "com.crocode.plinth",
  "build": {
    "beforeBuildCommand": "bun run build",
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Plinth",
        "width": 1024,
        "height": 768,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "dmg": {
        "background": "build-assets/dmg-img.png",
        "windowSize": {
          "width": 660,
          "height": 440
        },
        "appPosition": {
          "x": 170,
          "y": 230
        },
        "applicationFolderPosition": {
          "x": 430,
          "y": 210
        }
      }
    },
    "fileAssociations": [
      {
        "ext": ["3dpak", "3pk"],
        "name": "3D Model Package",
        "description": "3D Model Package for Plinth",
        "mimeType": "application/vnd.crocode.3dpak"
      }
    ]
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    }
  }
}
